# Copy to .env and edit values as needed. Never commit .env to git.

# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=finance_invoicing
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://app:changeme@postgres:5432/finance_invoicing

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT / Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
PASSWORD_PEPPER=change-this-too
SESSION_INACTIVITY_MINUTES=30
MAX_FAILED_LOGINS=5

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# Upload / Storage
STORAGE_BACKEND=local
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=20

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost
BOQ_TOTAL_TOLERANCE_PCT=0.5
UNIT_PRICE_TOLERANCE_PCT=0.0
VAT_RATE=0.15
LOW_CONFIDENCE_THRESHOLD=70

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost/api
